#!/usr/bin/env node
/*
 * ccmd — Command Center CLI (machine-wide agent status board)
 * A single board where every agent, across every project and session, reports
 * what it's doing, what's blocked, and what needs you.
 *
 * Store:    $ACC_HOME (default ~/.agents-command-center) — your data + config.
 * Package:  this file lives in skills/command-center/bin; the UI is in ../template.
 * No npm deps. Every command exits 0 (never blocks a hook).
 * See reference.md for the full command surface, SKILL.md for the agent protocol.
 */
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');
const http = require('http');
const readline = require('readline');
const crypto = require('crypto');
const { execSync } = require('child_process');

// Store lives in the user's home (or $ACC_HOME); the package is read-only.
const HOME = process.env.ACC_HOME || path.join(os.homedir(), '.agents-command-center');
const PKG_DIR = path.join(__dirname, '..');
const TEMPLATE_DIR = path.join(PKG_DIR, 'template');
const DIRS = {
  entries: path.join(HOME, 'entries'),
  signals: path.join(HOME, 'signals'),
  seen: path.join(HOME, 'seen'),
  archive: path.join(HOME, 'archive'),
  goals: path.join(HOME, 'goals'),
};
const CONFIG_PATH = path.join(HOME, 'config.json');
const DASHBOARD_PATH = path.join(HOME, 'dashboard.html');
const DEMO_MARKER = path.join(HOME, '.demo-store'); // present only in a store seeded by `ccmd demo`

const STALE_MS = 6 * 60 * 60 * 1000; // 6h without update => greyed
const DEFAULT_ACCENT = '#0a84ff';
const DEFAULT_FEATURES = { goals: true, seen: true, mirror: false };

// ---------- tiny utils ----------
// The store can hold status text you don't want other local users to read, so we
// keep it private: dirs 0700, files 0600. On non-POSIX platforms these modes are
// best-effort (Windows ignores them) — hence the try/catch.
function chmodQuiet(p, mode) { try { fs.chmodSync(p, mode); } catch {} }
function ensureDirs() {
  // one-time migration: the "loops" feature was renamed to "goals".
  try {
    const oldDir = path.join(HOME, 'loops'), newDir = path.join(HOME, 'goals');
    if (fs.existsSync(oldDir) && !fs.existsSync(newDir)) fs.renameSync(oldDir, newDir);
  } catch {}
  try { fs.mkdirSync(HOME, { recursive: true, mode: 0o700 }); } catch {}
  chmodQuiet(HOME, 0o700); // tighten pre-existing installs
  for (const d of Object.values(DIRS)) { fs.mkdirSync(d, { recursive: true, mode: 0o700 }); chmodQuiet(d, 0o700); }
}
function readJSON(p, fallback) {
  let raw;
  try { raw = fs.readFileSync(p, 'utf8'); }
  catch { return fallback; } // missing (ENOENT) etc. → silent fallback, this is normal
  try { return JSON.parse(raw); }
  catch (e) {
    // Corrupt JSON is NOT normal: preserve the bytes (quarantine, never overwrite) and
    // surface a diagnostic so it can't silently become "empty state".
    try { fs.renameSync(p, p + '.corrupt-' + Date.now()); } catch {}
    process.stderr.write(`ccmd: corrupt JSON quarantined -> ${p}.corrupt-* (${e.message})\n`);
    return fallback;
  }
}
function writeAtomic(p, data) {
  fs.mkdirSync(path.dirname(p), { recursive: true, mode: 0o700 });
  const tmp = p + '.tmp-' + process.pid + '-' + Date.now();
  fs.writeFileSync(tmp, data, { mode: 0o600 });
  fs.renameSync(tmp, p);
}
function writeJSON(p, obj) { writeAtomic(p, JSON.stringify(obj, null, 2) + '\n'); }

function defaultConfig() {
  return {
    products: [],
    theme: 'swiss',
    accent: DEFAULT_ACCENT,
    features: Object.assign({}, DEFAULT_FEATURES),
    mirrorUrl: null,
    lastPresence: null,
    staleMs: STALE_MS,
  };
}
function loadConfig() {
  const c = Object.assign(defaultConfig(), readJSON(CONFIG_PATH, {}));
  const f = c.features || {};
  // back-compat: the "loops" toggle was renamed to "goals". Honor the old key.
  if (f.goals === undefined && f.loops !== undefined) f.goals = f.loops;
  c.features = Object.assign({}, DEFAULT_FEATURES, f);
  delete c.features.loops;
  if (!Array.isArray(c.products)) c.products = [];
  return c;
}
function saveConfig(c) { writeJSON(CONFIG_PATH, c); }
function feat(name) { const f = loadConfig().features; return f[name] !== false && (name in f ? f[name] : DEFAULT_FEATURES[name]); }

function sh(cmd) {
  try { return execSync(cmd, { stdio: ['ignore', 'pipe', 'ignore'] }).toString().trim(); }
  catch { return ''; }
}
function gitTop() { return sh('git rev-parse --show-toplevel'); }
function gitBranch() { return sh('git rev-parse --abbrev-ref HEAD'); }

function slug(s) {
  return String(s || '').replace(/[^A-Za-z0-9._@-]+/g, '_').replace(/^_+|_+$/g, '') || 'x';
}
function shortHash(s) { return crypto.createHash('sha1').update(String(s)).digest('hex').slice(0, 16); }
// Injective, filesystem+grammar-safe encoding — the reversible counterpart to slug().
// Keeps [A-Za-z0-9._-]; every other byte (incl. '/' and '~') → ~HH. So `feat/foo`
// and `feat_foo` map to DISTINCT ids (slug collapses both to `feat_foo`). Guards
// against a `.`/`..` segment ever becoming a path-traversal filename.
function enc(s) {
  let out = String(s == null ? '' : s).replace(/[^A-Za-z0-9._-]/g, c => '~' + c.charCodeAt(0).toString(16).padStart(2, '0'));
  if (out === '' || out === 'x') out = out || 'x';
  if (out === '.' || out === '..') out = out.replace(/\./g, '~2e'); // never a traversal segment
  if (out.length > 150) out = out.slice(0, 120) + '~h' + shortHash(s); // bound filename length, stay unique
  return out;
}
// A "key" identifies a board item for read-tracking: entry:<project>/<encBranch> or signal:<id>.
// The seen marker filename is a hash of the key — collision-free even where slug() would clash.
function keyToFile(key) { return path.join(DIRS.seen, 'k-' + shortHash(key)); }
function legacyKeyFile(key) { return path.join(DIRS.seen, slug(key)); } // pre-hash markers
function isSeen(key) { return fs.existsSync(keyToFile(key)) || fs.existsSync(legacyKeyFile(key)); }
function markSeen(key) { writeAtomic(keyToFile(key), new Date().toISOString() + '\n'); }
function clearSeen(key) { try { fs.unlinkSync(keyToFile(key)); } catch {} try { fs.unlinkSync(legacyKeyFile(key)); } catch {} }

// The on-disk path for an entry key — the single source of truth used by report,
// prune, check and validKey, so they can never disagree.
function entryPathFromKey(key) {
  const rest = key.slice(6); // after "entry:"
  const i = rest.indexOf('/');
  return path.join(DIRS.entries, rest.slice(0, i), rest.slice(i + 1) + '.json');
}

// Strict grammar for a board key: `entry:<project>/<branch>` or `signal:<id>`.
// `~` is allowed (the enc() escape). The referenced item must exist — so /seen and
// the `ccmd-read:` relay can never mint or traverse to arbitrary files.
const SEG = '[A-Za-z0-9._@~-]{1,160}';
const KEY_RE = new RegExp(`^(?:entry:${SEG}/${SEG}|signal:${SEG})$`);
function validKeyFormat(key) { return typeof key === 'string' && key.length <= 360 && KEY_RE.test(key); }
function validKey(key) {
  if (!validKeyFormat(key)) return false;
  if (key.startsWith('entry:')) return fs.existsSync(entryPathFromKey(key));
  const id = key.slice(7);
  return fs.existsSync(path.join(DIRS.signals, id + '.json'));
}

// A store is "demo" only if `ccmd demo` seeded it (marker file). Any real write clears it,
// so `ccmd demo` can never silently clobber real data (blocker: demo data-loss).
function isDemoStore() { return fs.existsSync(DEMO_MARKER); }
function markDemoStore() { try { writeAtomic(DEMO_MARKER, new Date().toISOString() + '\n'); } catch {} }
function clearDemoMarker() { try { fs.unlinkSync(DEMO_MARKER); } catch {} }
function storeHasData() {
  const anyIn = (dir, nested) => {
    for (const a of safeReaddir(dir)) {
      if (nested) { if (safeReaddir(path.join(dir, a)).some(f => f.endsWith('.json'))) return true; }
      else if (a.endsWith('.json')) return true;
    }
    return false;
  };
  return anyIn(DIRS.entries, true) || anyIn(DIRS.signals, false) || anyIn(DIRS.goals, false);
}

// ---------- arg parsing ----------
function parseArgs(argv) {
  const out = { _: [] };
  const push = (k, v) => { if (k in out) { out[k] = [].concat(out[k], v); } else out[k] = v; };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a.startsWith('--')) {
      const eq = a.indexOf('=');
      if (eq !== -1) { push(a.slice(2, eq), a.slice(eq + 1)); }
      else if (i + 1 < argv.length && !argv[i + 1].startsWith('--')) { push(a.slice(2), argv[++i]); }
      else { push(a.slice(2), true); }
    } else out._.push(a);
  }
  return out;
}
// split a repeatable-ish flag: ";" or "|" separated into an array (commas stay inside the item)
function list(v) {
  if (v == null || v === true) return [];
  if (Array.isArray(v)) return v.flatMap(list);
  return String(v).split(/\s*[;|]\s*/).map(s => s.trim()).filter(Boolean);
}

function context(args) {
  const top = gitTop();
  const project = args.project || (top ? path.basename(top) : path.basename(process.cwd()));
  let branch = args.branch || (top ? gitBranch() : '') || args.label || path.basename(process.cwd());
  if (branch === 'HEAD' || !branch) branch = 'detached';
  // rawBranch drives the collision-free key/id; branch (slug) stays for display.
  return { project: slug(project), branch: slug(branch), rawBranch: String(branch), cwd: process.cwd() };
}

// ---------- commands: report / signal ----------
function cmdReport(args) {
  ensureDirs();
  const { project, branch, rawBranch, cwd } = context(args);
  const encB = enc(rawBranch);
  const key = `entry:${project}/${encB}`;
  const status = String(args.status || 'IN_PROGRESS').toUpperCase().replace(/[^A-Z_]/g, '_');
  const entry = {
    key, project, branch, cwd,
    agent: args.agent || process.env.ACC_AGENT || null,
    tier: args.tier || process.env.ACC_TIER || null,
    status: ['IN_PROGRESS', 'BLOCKED', 'DONE'].includes(status) ? status : 'IN_PROGRESS',
    summary: args.summary || null,   // one sentence: what is happening NOW, with context
    task: args.task || null,         // ticket / PR / feature in flight
    progress: args.progress || null, // short progress: "PR #29 · CI green", "3/5 sections"
    done: list(args.done),
    inFlight: list(args['in-flight'] || args.inflight),
    next: list(args.next),
    blockedOn: list(args.blocked || args['blocked-on']),
    note: args.note || null,
    updatedAt: new Date().toISOString(),
  };
  const file = entryPathFromKey(key);
  writeJSON(file, entry);
  // Migrate away from the lossy slug filename for the same branch (avoids a duplicate row).
  if (encB !== slug(branch)) { try { fs.unlinkSync(path.join(DIRS.entries, project, slug(branch) + '.json')); } catch {} }
  clearSeen(key); // a fresh update re-surfaces the row
  clearDemoMarker(); // a real report means this is no longer a demo store
  process.stdout.write(`reported ${project}/${branch} [${entry.status}]\n`);
}

function cmdSignal(args) {
  ensureDirs();
  const { project, branch } = context(args);
  const kind = (args.kind || 'blocker').toLowerCase() === 'question' ? 'question' : 'blocker';
  const msg = args.msg || args.message || args._[0] || '(no message)';
  const id = Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 6);
  const sig = {
    key: `signal:${id}`, id, kind, project, branch,
    msg: String(msg),
    createdAt: new Date().toISOString(),
    resolved: false,
  };
  writeJSON(path.join(DIRS.signals, id + '.json'), sig);
  clearDemoMarker();
  process.stdout.write(`${id}\n`); // print id so the agent can `ccmd resolve <id>`
}

function cmdResolve(args) {
  const id = args._[0];
  if (!id) { process.stdout.write('usage: ccmd resolve <id>\n'); return; }
  const p = path.join(DIRS.signals, slug(id) + '.json');
  const sig = readJSON(p, null);
  if (!sig) { process.stdout.write(`no such signal: ${id}\n`); return; }
  sig.resolved = true;
  sig.resolvedAt = new Date().toISOString();
  writeJSON(path.join(DIRS.archive, 'signal-' + id + '.json'), sig);
  try { fs.unlinkSync(p); } catch {}
  clearSeen(`signal:${id}`);
  process.stdout.write(`resolved ${id}\n`);
}

// ---------- goals: curated async work with a verifiable end state ----------
// A "goal" is a chunk of agentic work that can run for hours without you until a
// completion condition is met. Agents curate the full prompt + specs/links and
// shelve it here (grouped by product) so you can fire one off with Claude Code's
// /goal any time. (Toggle: features.goals)
function cmdGoal(args) {
  if (!feat('goals')) { process.stdout.write('goals feature is off (set features.goals=true in config.json)\n'); return; }
  ensureDirs();
  fs.mkdirSync(DIRS.goals, { recursive: true });
  if (args._[0] === 'add') args._.shift(); // `ccmd goal add …` sugar == `ccmd goal …`
  if (args.done) {
    const p = path.join(DIRS.goals, slug(String(args.done)).toLowerCase().slice(0, 48) + '.json');
    const it = readJSON(p, null);
    if (!it) { process.stdout.write(`no such goal: ${args.done}\n`); return; }
    it.status = 'done'; it.updatedAt = new Date().toISOString();
    writeJSON(path.join(DIRS.archive, 'goal-' + it.id + '.json'), it);
    try { fs.unlinkSync(p); } catch {}
    process.stdout.write(`goal done ${it.id}\n`); return;
  }
  const idForTitle = args.id ? slug(String(args.id)).toLowerCase().slice(0, 48) : null;
  const prevForTitle = idForTitle ? readJSON(path.join(DIRS.goals, idForTitle + '.json'), {}) : {};
  const title = args.title || args._[0] || prevForTitle.title;
  if (!title) {
    process.stdout.write('usage: ccmd goal --title "…" --summary "…" [--prompt-path <file>] [--links "url;url"] [--prereqs "…"] [--hours N] [--status ready|waiting|draft] [--project p] [--id slug] | ccmd goal --done <id>\n');
    return;
  }
  const { project } = context(args);
  const id = slug(String(args.id || title)).toLowerCase().slice(0, 48);
  const p = path.join(DIRS.goals, id + '.json');
  const prev = readJSON(p, {});
  const status = String(args.status || prev.status || 'draft').toLowerCase();
  // waiting = curated & complete but a prereq is unmet (neither ready nor draft).
  const item = Object.assign({}, prev, {
    id,
    project: args.project || prev.project || project,
    title,
    summary: args.summary !== undefined ? String(args.summary) : (prev.summary || ''),
    promptPath: args['prompt-path'] !== undefined ? String(args['prompt-path']) : (prev.promptPath || null),
    links: list(args.links).length ? list(args.links) : (prev.links || []),
    prereqs: args.prereqs !== undefined ? String(args.prereqs) : (prev.prereqs || null),
    hours: args.hours !== undefined ? String(args.hours) : (prev.hours || null),
    status: ['ready', 'waiting', 'draft', 'done'].includes(status) ? status : 'draft',
    createdAt: prev.createdAt || new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  });
  writeJSON(p, item);
  clearDemoMarker();
  process.stdout.write(`goal ${item.id} [${item.status}]\n`);
}

function seenOff() {
  if (feat('seen')) return false;
  process.stdout.write('read-relay (seen) feature is off (set features.seen=true in config.json)\n');
  process.exitCode = 1; return true;
}
// `ccmd read` consumes a pasted `ccmd-read: k1, k2, …` line as STRUCTURED input
// (stdin or args) and validates every key internally — so the agent never has to
// interpolate untrusted tokens from the clipboard into a shell command.
function cmdRead(args) {
  if (seenOff()) return;
  let raw = '';
  if (args._.length) raw = args._.join(' ');
  else { try { if (!process.stdin.isTTY) raw = fs.readFileSync(0, 'utf8'); } catch {} }
  const m = /ccmd-read:\s*([^\n\r]+)/i.exec(raw) || (raw ? [null, raw] : null);
  if (!m) { process.stdout.write('usage: echo "ccmd-read: <keys>" | ccmd read\n'); process.exitCode = 1; return; }
  const tokens = m[1].split(',').map(s => s.trim()).filter(Boolean);
  let ok = 0, bad = 0;
  for (const k of tokens) {
    if (validKeyFormat(k)) { markSeen(k); ok++; } else bad++; // never shells out; pure validation
  }
  process.stdout.write(`marked ${ok} read${bad ? ` (${bad} ignored — bad key format)` : ''}\n`);
}
function cmdSeen(args) { if (seenOff()) return; const k = args._[0]; if (!k || !validKeyFormat(k)) { process.stdout.write('usage: ccmd seen <entry:project/branch|signal:id>\n'); process.exitCode = 1; return; } markSeen(k); process.stdout.write(`seen ${k}\n`); }
function cmdUnseen(args) { if (seenOff()) return; const k = args._[0]; if (!k || !validKeyFormat(k)) { process.stdout.write('usage: ccmd unseen <entry:project/branch|signal:id>\n'); process.exitCode = 1; return; } clearSeen(k); process.stdout.write(`unseen ${k}\n`); }

function cmdSetUrl(args) {
  const url = args._[0] || args.url;
  const c = loadConfig();
  c.mirrorUrl = url || null;
  saveConfig(c);
  process.stdout.write(`mirrorUrl = ${c.mirrorUrl}\n`);
}
function cmdGetUrl() { process.stdout.write((loadConfig().mirrorUrl || '') + '\n'); }

// ccmd check --since <epoch_ms>: does the cwd's entry exist and is it newer than --since?
// Used by the Stop enforcement hook. Always exits 0.
function cmdCheck(args) {
  const { project, branch, rawBranch } = context(args);
  const file = entryPathFromKey(`entry:${project}/${enc(rawBranch)}`);
  let exists = false, mtimeMs = null;
  try { const st = fs.statSync(file); exists = true; mtimeMs = Math.round(st.mtimeMs); } catch {}
  const since = Number(args.since || 0) || 0;
  const fresh = exists && (since ? mtimeMs >= since : true);
  process.stdout.write(JSON.stringify({ project, branch, file, exists, mtimeMs, fresh }) + '\n');
}

// ---------- gather board state from disk ----------
function safeReaddir(d) { try { return fs.readdirSync(d); } catch { return []; } }
function collect() {
  ensureDirs();
  const entries = [];
  const projRoot = DIRS.entries;
  for (const proj of safeReaddir(projRoot)) {
    for (const f of safeReaddir(path.join(projRoot, proj))) {
      if (!f.endsWith('.json')) continue;
      const e = readJSON(path.join(projRoot, proj, f), null);
      if (e) { e.seen = isSeen(e.key); entries.push(e); }
    }
  }
  const signals = [];
  for (const f of safeReaddir(DIRS.signals)) {
    if (!f.endsWith('.json')) continue;
    const s = readJSON(path.join(DIRS.signals, f), null);
    if (s && !s.resolved) { s.seen = isSeen(s.key); signals.push(s); }
  }
  return { entries, signals };
}

function cmdPrune(args) {
  const { entries } = collect();
  const seenOn = feat('seen');
  let archived = 0;
  for (const e of entries) {
    // With the read-relay feature off, "seen" has no meaning — only DONE is archived.
    if (!(e.status === 'DONE' || (seenOn && e.seen))) continue;
    const src = entryPathFromKey(e.key);
    // Compare-and-swap via atomic rename: claim the file, then verify it's still the
    // exact version collect() saw. A concurrent `report` (writeAtomic = temp+rename)
    // either lands before our claim (we detect a newer updatedAt and restore it) or
    // after (it recreates src fresh, we archive the old copy we hold). Either way a
    // fresh report is never deleted.
    const held = src + '.prune-' + process.pid + '-' + Date.now();
    try { fs.renameSync(src, held); } catch { continue; } // already gone → nothing to do
    const cur = readJSON(held, null);
    if (!cur || cur.updatedAt !== e.updatedAt) {
      try { fs.renameSync(held, src); } catch {} // changed under us → put it back, skip
      continue;
    }
    writeJSON(path.join(DIRS.archive, `entry-${e.project}-${shortHash(e.key)}-${Date.now()}.json`), cur);
    try { fs.unlinkSync(held); } catch {}
    clearSeen(e.key);
    archived++;
  }
  if (args.presence) { const c = loadConfig(); c.lastPresence = new Date().toISOString(); saveConfig(c); }
  cmdRender({ quiet: true });
  if (!args.quiet) process.stdout.write(`pruned ${archived} entr${archived === 1 ? 'y' : 'ies'}\n`);
}

// ---------- products (grouping of repos, from config) ----------
function products() {
  const cfg = loadConfig();
  return (cfg.products || []).map(p => ({
    id: slug(p.id || p.label || 'product'),
    label: p.label || p.id || 'Product',
    icon: p.icon || 'compass',
    repos: Array.isArray(p.repos) ? p.repos : [],
  }));
}
function productFor(proj) {
  return products().find(p => p.repos.includes(proj)) ||
    { id: slug(proj), label: proj, icon: 'compass', repos: [proj] };
}
function productOrder(id) { const arr = products(); const i = arr.findIndex(x => x.id === id); return i === -1 ? 99 : i; }

// ---------- board model (shared by buildHTML and `ccmd data`) ----------
function timeAgo(iso) {
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.round(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
function esc(s) {
  return String(s == null ? '' : s).replace(/[&<>"']/g, c => (
    { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
}
// Autolink URLs over already-escaped text (the &amp; inside an href is valid HTML).
function linkify(escaped) {
  return escaped.replace(/https?:\/\/[^\s<]+/g, u => {
    const label = u.replace(/^https?:\/\//, '').replace(/\/$/, '');
    return `<a class="prlink" href="${u}" target="_blank" rel="noreferrer">${label}</a>`;
  });
}

// UI status: worst state wins. stale (no update > staleMs, not DONE) => idle.
function uiStatus(e, staleMs, now) {
  const stale = e.status !== 'DONE' && (now - new Date(e.updatedAt).getTime()) > staleMs;
  if (stale) return { cls: 'idle', label: 'No signal · ' + timeAgo(e.updatedAt), stale: true };
  if (e.status === 'BLOCKED') return { cls: 'need', label: 'Needs you', stale: false };
  if (e.status === 'DONE') return { cls: 'ready', label: 'Ready', stale: false };
  return { cls: 'doing', label: 'In progress', stale: false };
}
const CLS_RANK = { need: 0, doing: 1, ready: 2, idle: 3 };

// Overview = triage: one line per item; the detail lives in the product's tab.
function brief(text, max = 110) {
  const s = String(text || '').replace(/\s+/g, ' ').trim();
  const dot = s.indexOf('. ');
  if (dot > 24 && dot < max) return s.slice(0, dot + 1);
  return s.length > max ? s.slice(0, max - 1).trimEnd() + '…' : s;
}

function boardModel() {
  const { entries, signals } = collect();
  const cfg = loadConfig();
  const staleMs = cfg.staleMs || STALE_MS;
  const now = Date.now();
  const seenOn = feat('seen');
  // Entries: a read report drops off the board (only when the feature is on).
  const visEntries = entries.filter(e => seenOn ? !e.seen : true)
    .map(e => Object.assign({}, e, { ui: uiStatus(e, staleMs, now) }))
    .sort((a, b) => (CLS_RANK[a.ui.cls] - CLS_RANK[b.ui.cls]) || (a.updatedAt < b.updatedAt ? 1 : -1));
  // Signals leave the board only when RESOLVED. "read" just dims them and drops
  // them from the urgency surfaces — an unresolved blocker/question stays visible.
  const allSignals = signals.slice().sort((a, b) => (a.createdAt < b.createdAt ? 1 : -1));
  const isUrgent = (s) => !(seenOn && s.seen);
  const visSignals = allSignals;                 // shown in product tabs (read = dimmed)
  const urgentSignals = allSignals.filter(isUrgent); // drive prio + counts + "needs you"

  const groups = new Map();
  const groupFor = (proj) => {
    const p = productFor(proj);
    if (!groups.has(p.id)) groups.set(p.id, { id: p.id, label: p.label, icon: p.icon, repos: p.repos, entries: [], signals: [] });
    return groups.get(p.id);
  };
  for (const e of visEntries) groupFor(e.project).entries.push(e);
  for (const s of visSignals) groupFor(s.project).signals.push(s);

  const grouped = Array.from(groups.values());
  for (const g of grouped) {
    const present = new Set(g.entries.map(e => e.project).concat(g.signals.map(s => s.project)));
    g.reposLine = Array.from(present).join(' · ');
    const gUrgent = g.signals.filter(isUrgent);
    const worst = gUrgent.length || g.entries.some(e => e.ui.cls === 'need') ? ['need', 'Needs you']
      : g.entries.some(e => e.ui.cls === 'doing') ? ['doing', 'In progress']
      : g.entries.some(e => e.ui.cls === 'ready') ? ['ready', 'Ready']
      : g.signals.length ? ['idle', 'Acknowledged'] // read-but-unresolved
      : ['idle', 'No signal'];
    g.summaryStatus = worst;
    const latest = g.entries.slice().sort((a, b) => (a.updatedAt < b.updatedAt ? 1 : -1))[0];
    g.summaryLine = (gUrgent[0] && gUrgent[0].msg) || (g.signals[0] && g.signals[0].msg) || (latest && latest.summary) || '';
    const q = g.signals.filter(s => s.kind === 'question').length;
    const bl = g.signals.length - q;
    const doing = g.entries.filter(e => e.ui.cls === 'doing').length;
    const ready = g.entries.filter(e => e.ui.cls === 'ready').length;
    g.countsLine = [
      q ? `${q} question${q > 1 ? 's' : ''}` : '',
      bl ? `${bl} blocker${bl > 1 ? 's' : ''}` : '',
      doing ? `${doing} in progress` : '',
      ready ? `${ready} to review` : '',
    ].filter(Boolean).join(' · ') || 'nothing pending';
  }
  grouped.sort((a, b) => (CLS_RANK[a.summaryStatus[0]] - CLS_RANK[b.summaryStatus[0]]) || a.label.localeCompare(b.label));

  // Overview priorities: ONE line per item (brief) + jump to the product tab for detail.
  // Only URGENT (unread) signals nag you here; acknowledged-but-unresolved ones live in their tab.
  const prio = [];
  for (const s of urgentSignals) {
    prio.push({
      t: brief(s.msg),
      d: `<code>${esc(productFor(s.project).label)}</code> · ${s.kind === 'question' ? 'question' : 'blocker'} · ${timeAgo(s.createdAt)} · detail in its tab`,
      jump: productFor(s.project).id,
      target: s.key,
    });
  }
  for (const e of visEntries.filter(e => e.ui.cls === 'need')) {
    const why = (e.blockedOn && e.blockedOn.length) ? esc(brief(e.blockedOn.join(' · '), 80)) + ' · ' : '';
    prio.push({ t: brief((e.task || e.branch) + ': blocked'), d: `${why}<code>${esc(productFor(e.project).label)}</code>`, jump: productFor(e.project).id, target: e.key });
  }
  for (const e of visEntries.filter(e => e.ui.cls === 'ready' && e.next && e.next.length)) {
    prio.push({ t: brief((e.task || e.branch) + ': ready, your turn'), d: `${esc(brief(e.next.join(' · '), 80))} · <code>${esc(productFor(e.project).label)}</code>`, jump: productFor(e.project).id, target: e.key });
  }
  prio.length = Math.min(prio.length, 6);

  const stats = [
    { v: grouped.length, l: 'products reporting' },
    { v: visEntries.filter(e => e.ui.cls === 'doing').length, l: 'fronts in progress' },
    { v: urgentSignals.length + visEntries.filter(e => e.ui.cls === 'need').length, l: 'need your eyes' },
    { v: visEntries.filter(e => e.status === 'DONE').length, l: 'ready to review' },
  ];

  const GOAL_RANK = { ready: 0, waiting: 1, draft: 2 };
  const goals = feat('goals') ? safeReaddir(DIRS.goals)
    .filter(f => f.endsWith('.json'))
    .map(f => readJSON(path.join(DIRS.goals, f), null))
    .filter(Boolean)
    .filter(n => n.status !== 'done')
    .sort((a, b) => ((GOAL_RANK[a.status] ?? 9) - (GOAL_RANK[b.status] ?? 9)) || (a.updatedAt < b.updatedAt ? 1 : -1)) : [];

  return { products: grouped, entries: visEntries, signals: visSignals, prio, stats, staleMs, now, goals, cfg };
}

// ---------- rendering ----------
function loadTpl(name) {
  try { return fs.readFileSync(path.join(TEMPLATE_DIR, name), 'utf8'); } catch { return null; }
}
let ICONS = null;
function icons() {
  if (!ICONS) {
    try { ICONS = require(path.join(TEMPLATE_DIR, 'icons.js')); }
    catch { ICONS = { ICON: {}, STEP: {}, UI: { moon: '', sun: '', check: '', chevron: '', external: '' } }; }
  }
  return ICONS;
}
let THEMES = null;
function themes() {
  if (!THEMES) { try { THEMES = require(path.join(TEMPLATE_DIR, 'themes.js')); } catch { THEMES = { themeVars: () => '' }; } }
  return THEMES;
}

function entryCard(e, prodIcon, showAck) {
  const { UI } = icons();
  const metabits = [];
  if (e.progress) metabits.push(esc(e.progress));
  for (const x of (e.inFlight || [])) metabits.push(esc(x));
  if (e.done && e.done.length) metabits.push(`<b>${e.done.length} ✓</b> · ${esc(e.done[e.done.length - 1])}`);
  const meta = [e.project, e.branch, e.agent, e.tier].filter(Boolean).join(' · ');
  return `<article class="card${e.ui.stale ? ' stale' : ''}" data-ack="${esc(e.key)}">
    <div class="chead">
      <span class="pic">${prodIcon}</span>
      <div style="min-width:0"><div class="ct">${esc(e.task || e.branch)}</div><div class="cm">${esc(meta)} · ${timeAgo(e.updatedAt)}</div></div>
      <span style="margin-left:auto"><span class="status ${e.ui.cls}"><span class="d"></span>${esc(e.ui.label)}</span></span>
    </div>
    ${e.summary ? `<p class="body">${linkify(esc(e.summary))}</p>` : ''}
    ${metabits.length ? `<div class="metaline">${metabits.map(m => `<span>${m}</span>`).join('')}</div>` : ''}
    ${(e.blockedOn && e.blockedOn.length) ? `<div class="youmove"><div class="lbl">Your move</div><div class="txt">${esc(e.blockedOn.join(' · '))}</div></div>` : ''}
    ${(e.next && e.next.length) ? `<div class="detail"><span class="arw">Next</span> · ${esc(e.next.join(' · '))}</div>` : ''}
    ${e.note ? `<div class="cfoot">${linkify(esc(e.note))}</div>` : ''}
    ${showAck ? `<div class="ackrow"><button class="ack" type="button" data-key="${esc(e.key)}"><span class="box">${UI.check}</span><span class="lab">Mark read</span></button></div>` : ''}
  </article>`;
}

function signalCard(s, prodIcon, showAck) {
  const { UI } = icons();
  // Read but unresolved → dimmed + "Acknowledged"; it only leaves on `ccmd resolve`.
  const ack = showAck && s.seen;
  const status = ack ? ['idle', 'Acknowledged'] : ['need', 'Needs you'];
  return `<article class="card${ack ? ' read' : ''}" data-ack="${esc(s.key)}">
    <div class="chead">
      <span class="pic">${prodIcon}</span>
      <div style="min-width:0"><div class="ct">${s.kind === 'question' ? 'Open question' : 'Blocker'}</div><div class="cm">${esc(s.project)} · ${esc(s.branch)} · ${timeAgo(s.createdAt)}</div></div>
      <span style="margin-left:auto"><span class="status ${status[0]}"><span class="d"></span>${status[1]}</span></span>
    </div>
    <p class="body">${linkify(esc(s.msg))}</p>
    <div class="cfoot">clear with <code class="k">ccmd resolve ${esc(s.id)}</code></div>
    ${showAck ? `<div class="ackrow"><button class="ack" type="button" data-key="${esc(s.key)}"><span class="box">${UI.check}</span><span class="lab">${s.seen ? 'Read' : 'Mark read'}</span></button></div>` : ''}
  </article>`;
}

function buildHTML({ interactive, fragment }) {
  const css = loadTpl('style.css');
  const js = loadTpl('client.js');
  if (!css || !js) {
    const msg = '<style>body{font-family:system-ui;padding:48px;color:#333}</style>' +
      '<p><b>Command Center:</b> the template is missing (skills/command-center/template/style.css and client.js). Restore it to render the board.</p>';
    return fragment ? msg : `<!doctype html><html lang="en"><head><meta charset="utf-8"><title>Command Center</title></head><body>${msg}</body></html>`;
  }
  const { ICON, STEP, UI } = icons();
  const iconFor = (name) => ICON[name] || ICON.compass || '';
  const m = boardModel();
  const showGoals = feat('goals');
  const showAck = feat('seen');
  const hasData = m.entries.length || m.signals.length;

  // --- tabs. Product tabs are namespaced `p-<id>` so a product named "overview"/
  // "goals"/"command-center" can never collide with a reserved tab's DOM id.
  const ptab = (pid) => 'p-' + pid;
  const tabDefs = [{ id: 'overview', label: 'Overview' }]
    .concat(m.products.map(p => ({ id: ptab(p.id), label: p.label })));
  if (showGoals) tabDefs.push({ id: 'goals', label: `Goals${m.goals.length ? ` · ${m.goals.filter(n => n.status === 'ready').length}` : ''}` });
  tabDefs.push({ id: 'command-center', label: 'Command Center' });
  const segHTML = tabDefs.map((t, i) =>
    `<button role="tab" id="tab-${esc(t.id)}" data-tab="${esc(t.id)}" aria-controls="panel-${esc(t.id)}" aria-selected="${i === 0}" tabindex="${i === 0 ? '0' : '-1'}">${esc(t.label)}</button>`).join('');

  // --- panel: overview
  const prioHTML = m.prio.length
    ? m.prio.map((r, i) => `<button class="row" type="button" data-jump="${esc(ptab(r.jump))}"${r.target ? ` data-target="${esc(r.target)}"` : ''} title="See the detail in the tab"><div class="num">${i + 1}</div><div style="min-width:0"><div class="t">${esc(r.t)}</div><div class="d">${r.d}</div></div><span class="chev">${UI.chevron}</span></button>`).join('')
    : `<div class="empty">Nothing waiting on you right now. Blockers and questions land here.</div>`;
  const statsHTML = m.stats.map(s => `<div class="stat"><div class="v">${s.v}</div><div class="l">${esc(s.l)}</div></div>`).join('');
  const plistHTML = m.products.map(p => `
        <button class="pcard" data-jump="${esc(ptab(p.id))}">
          <span class="pic">${iconFor(p.icon)}</span>
          <span class="pmain"><span class="pn">${esc(p.label)}</span><span class="pr"><b>${esc(p.countsLine)}</b>${p.summaryLine ? ' — ' + esc(brief(p.summaryLine, 90)) : ''}</span></span>
          <span class="pside"><span class="status ${p.summaryStatus[0]}"><span class="d"></span>${esc(p.summaryStatus[1])}</span><span class="chev">${UI.chevron}</span></span>
        </button>`).join('');
  const overviewHTML = `<div class="panel on" role="tabpanel" id="panel-overview" aria-labelledby="tab-overview" data-tab="overview" tabindex="0">
    ${hasData ? `
    <section>
      <p class="kick">For you · when you're back</p>
      <div class="prio">${prioHTML}</div>
    </section>
    <section>
      <p class="kick">At a glance</p>
      <div class="stats">${statsHTML}</div>
    </section>
    <section>
      <p class="kick">Status by product</p>
      <div class="plist">${plistHTML}</div>
    </section>` : `
    <div class="void">
      <p class="vt">No agents reporting</p>
      <p class="vs">Cards show up here when an agent runs <code>ccmd report</code> or <code>ccmd signal</code>.</p>
    </div>`}
  </div>`;

  // --- panels: products
  const prodPanels = m.products.map(p => {
    const cards = p.signals.map(s => signalCard(s, iconFor(p.icon), showAck)).join('')
      + p.entries.map(e => entryCard(e, iconFor(p.icon), showAck)).join('');
    return `<div class="panel" role="tabpanel" id="panel-${esc(ptab(p.id))}" aria-labelledby="tab-${esc(ptab(p.id))}" data-tab="${esc(ptab(p.id))}" hidden tabindex="0">
      <p class="kick">${esc(p.label)} · ${esc(p.reposLine)}</p>
      <div class="stack">${cards}</div>
    </div>`;
  }).join('');

  // --- panel: goals (curated async work with a verifiable end state)
  let goalsHTML = '';
  if (showGoals) {
    const GOAL_UI = {
      ready: ['ready', 'Ready to run'],
      waiting: ['idle', 'Waiting on prereq'],
      draft: ['doing', 'Drafting'],
    };
    const goalCard = (n, prod) => {
      const ui = GOAL_UI[n.status] || GOAL_UI.draft;
      const metaBits = [n.hours ? `~${esc(String(n.hours))} h` : null, timeAgo(n.updatedAt)].filter(Boolean).join(' · ');
      const links = (n.links || []).map(u => linkify(esc(u))).join(' · ');
      return `<article class="card">
      <div class="chead">
        <span class="pic">${iconFor(prod.icon)}</span>
        <div style="min-width:0"><div class="ct">${esc(n.title)}</div><div class="cm">${metaBits}</div></div>
        <span style="margin-left:auto"><span class="status ${ui[0]}"><span class="d"></span>${ui[1]}</span></span>
      </div>
      ${n.summary ? `<p class="body">${linkify(esc(n.summary))}</p>` : ''}
      ${n.prereqs ? `<div class="youmove"><div class="lbl">Before running</div><div class="txt">${esc(n.prereqs)}</div></div>` : ''}
      ${n.promptPath ? `<div class="nprompt"><span class="lbl">Prompt</span><code class="k">${esc(n.promptPath)}</code></div>` : ''}
      ${links ? `<div class="cfoot">${links}</div>` : ''}
      <div class="cfoot" style="opacity:.75">fire it with Claude Code's <code class="k">/goal</code> and walk away · when it's done: <code class="k">ccmd goal --done ${esc(n.id)}</code></div>
    </article>`;
    };
    const goalGroups = [];
    for (const n of m.goals) {
      const prod = productFor(n.project);
      let g = goalGroups.find(x => x.prod.id === prod.id);
      if (!g) { g = { prod, items: [] }; goalGroups.push(g); }
      g.items.push(n);
    }
    goalGroups.sort((a, b) => productOrder(a.prod.id) - productOrder(b.prod.id));
    const goalCards = goalGroups.map((g, gi) => {
      const ready = g.items.filter(n => n.status === 'ready').length;
      const head = `<p class="kick" style="margin:${gi === 0 ? '0' : '30px'} 0 12px">${esc(g.prod.label)} · ${g.items.length} goal${g.items.length === 1 ? '' : 's'}${ready ? ` · ${ready} ready` : ''}</p>`;
      return head + `<div class="stack">${g.items.map(n => goalCard(n, g.prod)).join('')}</div>`;
    }).join('');
    goalsHTML = `<div class="panel" role="tabpanel" id="panel-goals" aria-labelledby="tab-goals" data-tab="goals" hidden tabindex="0">
      <p class="kick">Goals · curated async work with a finish line</p>
      <h2>Work that runs while you sleep.</h2>
      <p class="sub">Agents spot the work that can run for hours without you, curate the full prompt with specs, links and a completion condition, and shelve it here. You pick one any night, fire it with Claude Code's <code>/goal</code>, and go — your live hours stay for the synchronous work.</p>
      ${m.goals.length ? goalCards : `<div class="void"><p class="vt">No goals on the shelf</p><p class="vs">When an agent finds async-able work it leaves it here with <code>ccmd goal</code>.</p></div>`}
    </div>`;
  }

  // --- panel: command center (static meta)
  const flow = [
    { i: STEP.report, t: 'Agents report themselves', d: 'Every agent runs <code>ccmd report</code> when it closes a turn. An optional Stop hook blocks the close if the repo changed and nothing was reported.' },
    { i: STEP.build, t: 'The board is generated from the store', d: 'Everything you see comes from <code>entries/</code> and <code>signals/</code>. Nobody hand-edits HTML — the UI lives in <code>template/</code> and renders identically everywhere.' },
    { i: STEP.read, t: 'You mark what you read', d: 'Tap "Mark read" on a card. On <code>ccmd serve</code> it persists instantly; elsewhere "Copy what I read" builds a <code>ccmd-read: …</code> line with the real keys.' },
    { i: STEP.loop, t: 'The circle closes', d: 'Paste that line into any agent chat; it runs <code>ccmd seen</code> per key and the board drops those items.' },
  ];
  const flowSteps = showAck ? flow : flow.filter(s => s !== flow[2] && s !== flow[3]);
  const changelog = [
    { ver: 'now', t: 'Generated from the store, one UI', d: 'The board is 100% data-driven and renders identically for the local dashboard, the live server and an optional hosted mirror.', bullets: [
      'Overview = triage: one line per item and per-product counts; the full detail lives in each product tab, and every Overview card jumps to it.',
      'Cards come straight from <code>ccmd report</code> / <code>ccmd signal</code>, with the real store keys.',
      'Three themes (swiss / terminal / soft) + a custom accent, injected as CSS variables at render time.',
      'Feature toggles (goals / read-relay / mirror) turn tabs, commands and board sections on and off.',
    ] },
    { ver: 'why', t: 'We moved to local-first', d: 'This started life publishing an HTML mirror to a hosted artifact every turn. That was pure overhead — re-uploading the whole board on every report. The live <code>ccmd serve</code> at localhost is now the default; the mirror survives only as an optional adapter for teams that want a shared URL.', bullets: [] },
  ];
  const commandCenterHTML = `<div class="panel" role="tabpanel" id="panel-command-center" aria-labelledby="tab-command-center" data-tab="command-center" hidden tabindex="0">
    <p class="kick">Command Center · the meta-project</p>
    <h2>The loop, in ${showAck ? 'four' : 'two'} steps</h2>
    <p class="sub">How state flows from the agents to your eyes, and back.</p>
    <div class="flow">${flowSteps.map(s => `<div class="step"><span class="i">${s.i}</span><div><div class="t">${s.t}</div><div class="d">${s.d}</div></div></div>`).join('')}</div>
    <p class="kick">Changelog</p>
    <div class="log">${changelog.map(c => `<div class="logitem"><div class="lh"><span class="ver">${c.ver}</span><span class="lt">${c.t}</span></div><p class="ld">${c.d}</p>${c.bullets.length ? `<ul>${c.bullets.map(b => `<li>${b}</li>`).join('')}</ul>` : ''}</div>`).join('')}</div>
  </div>`;

  // --- header + shell
  const nowIso = new Date().toISOString();
  const updated = `Generated ${nowIso.slice(0, 10)} ${nowIso.slice(11, 16)} UTC · ${m.entries.length} ${m.entries.length === 1 ? 'agent' : 'agents'} · ${m.signals.length} ${m.signals.length === 1 ? 'signal' : 'signals'}`;
  const relayBlock = showAck ? `
<div class="relay" aria-live="polite">
  <span class="rc"><b class="rn">0</b> read</span>
  <button class="copy" type="button">Copy what I read</button>
  <button class="clear" type="button" title="Undo marks in this browser">clear</button>
</div>
<div class="relaybox">
  <p class="rbl">Selected. Copy with ⌘C / Ctrl-C and paste it into any agent chat; it drops these items from the board.</p>
  <textarea readonly rows="2" spellcheck="false"></textarea>
</div>
<div class="toast" role="status" aria-live="polite"></div>` : '';
  const bodyBlock = `<div class="wrap">
  <header class="top">
    <div class="bar">
      <p class="eyebrow">Command Center</p>
      <button class="tt" id="themeToggle" type="button" aria-label="Toggle light/dark">${UI.moon}${UI.sun}</button>
    </div>
    <h1 class="title">Where everything is, and what needs you.</h1>
    <p class="lede">A board of your agents, grouped by product. It generates itself from their reports; you mark what you read.</p>
    <p class="updated">${esc(updated)}</p>
  </header>
  <div class="segwrap"><div class="seg" role="tablist" aria-label="Sections" id="seg">${segHTML}</div></div>
  <main id="panels">${overviewHTML}${prodPanels}${goalsHTML}${commandCenterHTML}</main>
  <footer><span>Command Center · generated by ccmd</span><span>${showAck ? 'mark read and "Copy what I read" to clear items' : 'open-source agent status board'}</span></footer>
</div>${relayBlock}`;

  const themeCss = themes().themeVars(m.cfg.theme, m.cfg.accent);
  const styleBlock = `<style>\n${css}\n${themeCss}</style>`;
  const scriptBlock = `<script>window.CC_MODE={interactive:${interactive ? 'true' : 'false'}};</script>\n<script>\n${js}\n</script>`;

  if (fragment) return `<title>Command Center</title>\n${styleBlock}\n${bodyBlock}\n${scriptBlock}`;

  return `<!doctype html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Command Center</title>
${styleBlock}</head>
<body>${bodyBlock}${scriptBlock}</body></html>`;
}

function cmdRender(args) {
  const html = buildHTML({ interactive: true });
  writeAtomic(DASHBOARD_PATH, html);
  if (!args || !args.quiet) process.stdout.write(`rendered -> ${DASHBOARD_PATH}\n`);
}

function cmdMirror(args) {
  if (!feat('mirror')) { process.stdout.write('mirror feature is off (set features.mirror=true in config.json)\n'); return; }
  const out = args.out || path.join(HOME, 'mirror.html');
  const html = buildHTML({ interactive: false, fragment: !!args.fragment });
  writeAtomic(out, html);
  const c = loadConfig(); c.lastMirrorAt = new Date().toISOString(); saveConfig(c);
  process.stdout.write(out + '\n');
}

// ---------- data (JSON of the board model, for debug/other consumers) ----------
function cmdData() {
  const m = boardModel();
  const out = {
    updated: new Date().toISOString(),
    stats: m.stats,
    prio: m.prio.map(r => ({ t: r.t })),
    products: m.products.map(g => ({
      id: g.id, label: g.label, repos: g.reposLine,
      status: g.summaryStatus, summary: g.summaryLine,
      items: g.entries.map(e => ({
        key: e.key, title: e.task || e.branch,
        meta: [e.project, e.branch, e.agent].filter(Boolean).join(' · '),
        status: [e.ui.cls, e.ui.label], body: e.summary || '',
        progress: e.progress || null, inFlight: e.inFlight, next: e.next, blockedOn: e.blockedOn, note: e.note || null,
      })),
      signals: g.signals.map(s => ({ key: s.key, kind: s.kind, msg: s.msg, where: `${s.project}/${s.branch}`, id: s.id })),
    })),
  };
  process.stdout.write(JSON.stringify(out, null, 2) + '\n');
}

// ---------- server ----------
// A cheap fingerprint of the store: newest mtime + item count across the live
// dirs. The client polls /hash and only refreshes when this changes (no blind
// reload → no flicker).
function storeHash() {
  let newest = 0, count = 0;
  for (const d of [DIRS.entries, DIRS.signals, DIRS.goals, DIRS.seen]) {
    for (const a of safeReaddir(d)) {
      const p = path.join(d, a);
      let st; try { st = fs.statSync(p); } catch { continue; }
      if (st.isDirectory()) {
        for (const f of safeReaddir(p)) {
          let s2; try { s2 = fs.statSync(path.join(p, f)); } catch { continue; }
          count++; if (s2.mtimeMs > newest) newest = s2.mtimeMs;
        }
      } else { count++; if (st.mtimeMs > newest) newest = st.mtimeMs; }
    }
  }
  return `${count}-${Math.round(newest)}`;
}
function cmdServe(args) {
  ensureDirs();
  const port = parseInt(args.port || process.env.ACC_PORT || '7777', 10);
  // Reject cross-origin/rebinding: only localhost Host headers are served.
  const hostOk = (req) => {
    const h = String(req.headers.host || '');
    const name = h.replace(/:\d+$/, '');
    return name === 'localhost' || name === '127.0.0.1' || name === '[::1]' || name === '';
  };
  const server = http.createServer((req, res) => {
    if (!hostOk(req)) { res.writeHead(403).end(); return; }
    if (req.method === 'GET' && req.url === '/hash') {
      res.writeHead(200, { 'Content-Type': 'text/plain', 'Cache-Control': 'no-store' });
      res.end(storeHash());
      return;
    }
    if ((req.url === '/seen' || req.url === '/unseen')) {
      if (!feat('seen')) { res.writeHead(404).end(); return; } // feature off → no read endpoint
      if (req.method !== 'POST') { res.writeHead(405).end(); return; }
      const ct = String(req.headers['content-type'] || '');
      if (!ct.includes('application/json')) { res.writeHead(415).end(); return; }
      let body = '', done = false;
      const fail = (code) => { if (done) return; done = true; try { res.writeHead(code).end(); } catch {} try { req.destroy(); } catch {} };
      req.on('error', () => {});
      req.on('data', c => { if (done) return; body += c; if (body.length > 1e5) fail(413); });
      req.on('end', () => {
        if (done) return; done = true;
        try {
          const { key } = JSON.parse(body || '{}');
          // Only keys that already exist on the board may be toggled — /seen can't mint arbitrary files.
          if (key && validKey(key)) (req.url === '/seen' ? markSeen : clearSeen)(key);
        } catch {}
        res.writeHead(204).end();
      });
      return;
    }
    if (req.method !== 'GET') { res.writeHead(405).end(); return; }
    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-store', 'X-Content-Type-Options': 'nosniff' });
    res.end(buildHTML({ interactive: true }));
  });
  server.on('error', (e) => { process.stderr.write(`serve error: ${e.message}\n`); process.exitCode = 1; process.exit(1); });
  server.listen(port, '127.0.0.1', () => {
    process.stdout.write(`Command Center → http://localhost:${port}\n`);
  });
}

// ---------- init (first-run setup: wizard OR non-interactive flags) ----------
const THEME_NAMES = ['swiss', 'terminal', 'soft'];
function parseProductArg(v) {
  // "id:Label:repo1,repo2"  or  "id:Label:icon:repo1,repo2"
  const items = [].concat(v).filter(x => typeof x === 'string');
  return items.map(raw => {
    const parts = raw.split(':');
    if (parts.length < 2) return null;
    let id = parts[0].trim(), label = parts[1].trim(), icon = 'compass', reposStr = '';
    if (parts.length >= 4) { icon = parts[2].trim() || 'compass'; reposStr = parts.slice(3).join(':'); }
    else if (parts.length === 3) { reposStr = parts[2]; }
    const repos = reposStr.split(',').map(s => s.trim()).filter(Boolean);
    return { id: slug(id), label: label || id, icon, repos: repos.length ? repos : [slug(id)] };
  }).filter(Boolean);
}
function writeConfigFrom({ products, theme, accent, features }, base) {
  const c = Object.assign(base || defaultConfig(), {});
  if (products) c.products = products;
  if (theme) c.theme = THEME_NAMES.includes(theme) ? theme : 'swiss';
  if (accent) c.accent = accent;
  if (features) c.features = features;
  saveConfig(c);
  return c;
}
function cmdInit(args) {
  ensureDirs();
  const hasFlags = args.theme || args.accent || args.features || args.product || args.yes || args.force;
  if (hasFlags || !process.stdin.isTTY) {
    // non-interactive
    const products = args.product ? parseProductArg(args.product) : [];
    let features = null;
    if ('features' in args) { // present (even empty) => authoritative; empty means all off
      const on = new Set(list(String(args.features === true ? '' : args.features).replace(/,/g, ';')));
      features = { goals: on.has('goals') || on.has('loops'), seen: on.has('seen'), mirror: on.has('mirror') };
    }
    const base = fs.existsSync(CONFIG_PATH) && !args.force ? loadConfig() : defaultConfig();
    const c = writeConfigFrom({
      products: products.length ? products : (base.products.length ? base.products : undefined),
      theme: args.theme,
      accent: args.accent,
      features,
    }, base);
    process.stdout.write(`wrote ${CONFIG_PATH}\n  theme=${c.theme} accent=${c.accent} products=${c.products.length} features=${Object.keys(c.features).filter(k => c.features[k]).join(',') || 'core-only'}\n`);
    if (args.slash || args['install-slash']) cmdInstall({});
    else process.stdout.write(`  Tip: run 'ccmd install' to add the /ccmd slash command for Claude Code.\n`);
    cmdRender({ quiet: true });
    return;
  }
  // interactive wizard (readline, no deps)
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const ask = (q, def) => new Promise(res => rl.question(def ? `${q} [${def}] ` : `${q} `, a => res((a || '').trim() || def || '')));
  (async () => {
    process.stdout.write('\nCommand Center · setup\n———————————————————————\n');
    const products = [];
    process.stdout.write('\nProducts group your repos into board tabs.\n');
    for (;;) {
      const id = await ask(`Product id (blank to finish, ${products.length} added):`, '');
      if (!id) break;
      const label = await ask('  Label:', id);
      const repos = (await ask('  Repos (comma-separated):', id)).split(',').map(s => s.trim()).filter(Boolean);
      const icon = await ask('  Icon (compass/box/cube/globe/terminal/cloud/page/spark):', 'compass');
      products.push({ id: slug(id), label, icon: icon || 'compass', repos: repos.length ? repos : [slug(id)] });
    }
    const theme = (await ask(`\nTheme (${THEME_NAMES.join('/')}):`, 'swiss')).toLowerCase();
    const accent = await ask('Accent color (hex):', DEFAULT_ACCENT);
    const yn = (q, d) => ask(q + ' (y/n):', d).then(a => /^y/i.test(a));
    const features = {
      goals: await yn('Enable goals (async work shelf)?', 'y'),
      seen: await yn('Enable read-relay (mark read / copy)?', 'y'),
      mirror: await yn('Enable hosted mirror export?', 'n'),
    };
    const wantSlash = await yn('Add the /ccmd slash command for Claude Code?', 'y');
    rl.close();
    const c = writeConfigFrom({ products, theme, accent, features }, defaultConfig());
    process.stdout.write(`\nwrote ${CONFIG_PATH}\n`);
    if (wantSlash) cmdInstall({});
    process.stdout.write(`Run \`ccmd demo\` to preview, or \`ccmd serve\` and open http://localhost:7777\n`);
    cmdRender({ quiet: true });
  })();
}

// ---------- demo (seed a realistic example store for screenshots/preview) ----------
function cmdDemo(args) {
  ensureDirs();
  // demo resets the store — refuse to clobber real data unless --force or a fresh/demo store.
  // Refuse to reset unless this is a demo store (marker) or --force. A store with
  // ONLY signals, ONLY goals, or a single real report all count as real data.
  if (storeHasData() && !isDemoStore() && !(args && args.force)) {
    process.stdout.write(`ccmd demo resets the store, but ${HOME} already has real data.\n` +
      `  Re-run with --force to overwrite it, or point ACC_HOME at a throwaway dir:\n` +
      `  ACC_HOME=/tmp/acc-demo ccmd demo\n`);
    process.exitCode = 1;
    return;
  }
  const base = fs.existsSync(CONFIG_PATH) ? loadConfig() : defaultConfig();
  const demoProducts = [
    { id: 'acme-web', label: 'Acme Web', icon: 'globe', repos: ['acme-web', 'acme-marketing'] },
    { id: 'acme-api', label: 'Acme API', icon: 'terminal', repos: ['acme-api', 'acme-workers'] },
    { id: 'docs', label: 'Docs', icon: 'page', repos: ['docs'] },
  ];
  const c = Object.assign(base, { products: demoProducts });
  c.features = Object.assign({}, DEFAULT_FEATURES, { mirror: false }, base.features || {});
  c.theme = c.theme || 'swiss';
  c.accent = c.accent || DEFAULT_ACCENT;
  saveConfig(c);
  // clear prior demo data
  for (const d of [DIRS.entries, DIRS.signals, DIRS.goals]) { try { fs.rmSync(d, { recursive: true, force: true }); } catch {} }
  ensureDirs();
  const iso = (minsAgo) => new Date(Date.now() - minsAgo * 60000).toISOString();
  const entry = (o) => { const key = `entry:${o.project}/${enc(o.branch)}`;
    writeJSON(entryPathFromKey(key), Object.assign({ key, done: [], inFlight: [], next: [], blockedOn: [] }, o)); };
  entry({ project: 'acme-web', branch: 'feat/checkout-v2', status: 'IN_PROGRESS', agent: 'opus', tier: 'max',
    summary: 'Rebuilding the checkout as a 3-step flow; address + payment done, review step wired, running the Stripe test suite now.',
    task: 'PROJ-412 / PR #88', progress: '2/3 steps · CI green', inFlight: ['stripe test-mode e2e'], next: ['ship review step', 'copy pass'], updatedAt: iso(6) });
  entry({ project: 'acme-web', branch: 'fix/hero-cls', status: 'DONE', agent: 'sonnet',
    summary: 'Fixed the layout shift in the hero — reserved the image box, CLS down from 0.21 to 0.01. Ready to merge.',
    task: 'PROJ-408 / PR #90', next: ['review + merge'], done: ['measured before/after', 'lighthouse pass'], updatedAt: iso(22) });
  entry({ project: 'acme-api', branch: 'feat/rate-limit', status: 'BLOCKED', agent: 'opus', tier: 'max',
    summary: 'Token-bucket rate limiter is built and tested, but I need the per-plan limits before wiring the paid tiers.',
    task: 'PROJ-377 / PR #71', progress: 'core done · tiers pending', blockedOn: ['confirm limits: free 60/min, pro 600/min?'], updatedAt: iso(48) });
  entry({ project: 'docs', branch: 'main', status: 'IN_PROGRESS', agent: 'haiku',
    summary: 'Porting the API reference to the new docs site; 14 of 20 endpoints migrated with runnable examples.',
    progress: '14/20 endpoints', inFlight: ['migrating /webhooks'], next: ['migrate remaining 6'], updatedAt: iso(90) });
  const signal = (o) => { const id = o.id; writeJSON(path.join(DIRS.signals, id + '.json'), Object.assign({ key: `signal:${id}`, resolved: false }, o)); };
  signal({ id: 'demo-q1', kind: 'question', project: 'acme-web', branch: 'feat/checkout-v2',
    msg: 'Guest checkout for the review step: allow it, or force account creation before payment? Affects PROJ-412 — the review UI is built both ways behind a flag, I just need the call.', createdAt: iso(9) });
  signal({ id: 'demo-b1', kind: 'blocker', project: 'acme-api', branch: 'feat/rate-limit',
    msg: 'Need the per-plan rate limits to finish PROJ-377 (PR #71). Proposing free 60/min, pro 600/min — approve or give numbers and I ship the tiers.', createdAt: iso(47) });
  const goal = (o) => writeJSON(path.join(DIRS.goals, slug(o.id).toLowerCase().slice(0, 48) + '.json'),
    Object.assign({ links: [], createdAt: iso(120), updatedAt: iso(30) }, o));
  goal({ id: 'migrate-tests-to-vitest', project: 'acme-web', title: 'Migrate the test suite from Jest to Vitest', status: 'ready', hours: '5',
    summary: '~180 test files, mechanical but large: swap runner, fix config, update mocks, get CI green.', promptPath: 'goals/acme-web/vitest-migration.md', links: ['https://example.com/acme/issues/533'] });
  goal({ id: 'audit-api-error-codes', project: 'acme-api', title: 'Audit and unify API error codes', status: 'waiting', hours: '4',
    summary: 'Sweep every handler, map ad-hoc errors to the shared taxonomy, document each code.', prereqs: 'the error-taxonomy RFC has to merge first', promptPath: 'goals/acme-api/error-audit.md' });
  goal({ id: 'docs-screenshot-refresh', project: 'docs', title: 'Refresh every screenshot in the docs', status: 'draft', hours: '3',
    summary: 'Re-capture all product screenshots against the new UI, at 2x, and swap them in.', promptPath: 'goals/docs/screenshot-refresh.md' });
  markDemoStore(); // any subsequent real write (report/signal/goal) clears this
  cmdRender({ quiet: true });
  process.stdout.write(`seeded demo store at ${HOME}\n  4 entries · 2 signals · 3 goals · products: ${demoProducts.map(p => p.id).join(', ')}\n  run: ccmd serve   → http://localhost:7777\n`);
}

// ---------- link (make `ccmd` a real command on PATH) ----------
function cmdLink(args) {
  const target = path.resolve(__filename); // this bundled binary (has the shebang + +x)
  const candidates = args.dir ? [String(args.dir)] : [path.join(os.homedir(), '.local', 'bin'), '/usr/local/bin'];
  const pathDirs = (process.env.PATH || '').split(path.delimiter);
  for (const d of candidates) {
    try {
      fs.mkdirSync(d, { recursive: true });
      const link = path.join(d, 'ccmd');
      let st = null; try { st = fs.lstatSync(link); } catch {}
      if (st) {
        // Only replace something that is already a `ccmd` symlink — never clobber a
        // real binary or a foreign file without --force (and back it up if we do).
        let ours = false;
        if (st.isSymbolicLink()) { try { ours = path.basename(fs.readlinkSync(link)) === 'ccmd'; } catch {} }
        if (!ours && !args.force) {
          process.stdout.write(`refusing to overwrite ${link} — it isn't a ccmd symlink.\n  Re-run with --force (backed up to ccmd.bak) or use --dir <other>.\n`);
          process.exitCode = 1; return;
        }
        if (!ours) { try { fs.renameSync(link, link + '.bak'); } catch {} } else { try { fs.unlinkSync(link); } catch {} }
      }
      // atomic replace: create a temp symlink then rename over the target
      const tmp = link + '.tmp-' + process.pid + '-' + Date.now();
      fs.symlinkSync(target, tmp);
      fs.renameSync(tmp, link);
      process.stdout.write(`linked ccmd -> ${link}\n`);
      if (pathDirs.includes(d)) process.stdout.write(`  ${d} is on your PATH — 'ccmd' is ready.\n`);
      else process.stdout.write(`  ${d} is NOT on your PATH yet. Add:  export PATH="${d}:$PATH"\n`);
      return;
    } catch { /* try the next dir */ }
  }
  process.stdout.write(`could not create the link. Run ccmd by its absolute path:\n  ${target}\n`);
  process.exitCode = 1;
}

function cmdWhere() { process.stdout.write(path.resolve(__filename) + '\n'); }

// ---------- install (write a Claude Code slash command that runs this CLI) ----------
function slashCommandBody(target, name) {
  return `---
description: Command Center — run the ccmd status-board CLI (serve, goal, report, init, …)
argument-hint: [serve|goal|report|init|link|render] [args]
---
The Command Center CLI (\`ccmd\`) is bundled at this absolute path:

\`${target}\`

Run \`${target} $ARGUMENTS\` with the Bash tool, **from the current repository** so
its git project/branch context is right.

\`serve\` is a long-running process. Do NOT silently background it — the user should
own that process. When asked to serve (or when \`$ARGUMENTS\` is empty), either give
the user the exact command to run in their own terminal:

    ${target} serve      # → http://localhost:7777  (Ctrl-C to stop)

…or ask whether they'd like you to start it in the background for them. Let them choose.

Notes: \`ccmd\` writes only to the local store under \`$ACC_HOME\` (default
\`~/.agents-command-center\`) and never needs the network. For the full reporting
protocol (when to report / signal / shelve goals), load the \`command-center\`
skill. Never hand-edit the board HTML.
`;
}
const INSTALL_SIG = 'run the ccmd status-board CLI'; // stable marker: a slash file we wrote
function cmdInstall(args) {
  const target = path.resolve(__filename);
  const name = args.name ? slug(String(args.name)).toLowerCase() : 'ccmd';
  const dir = args.dir ? String(args.dir) : path.join(os.homedir(), '.claude', 'commands');
  try {
    fs.mkdirSync(dir, { recursive: true });
    const file = path.join(dir, name + '.md');
    if (fs.existsSync(file)) {
      let cur = ''; try { cur = fs.readFileSync(file, 'utf8'); } catch {}
      const ours = cur.includes(INSTALL_SIG);
      if (!ours && !args.force) {
        process.stdout.write(`refusing to overwrite /${name} at ${file} — it wasn't created by ccmd.\n  Re-run with --force (a .bak is kept) or use --name <other>.\n`);
        process.exitCode = 1; return;
      }
      if (!ours && args.force) { try { fs.copyFileSync(file, file + '.bak'); } catch {} }
    }
    writeAtomic(file, slashCommandBody(target, name)); // atomic (temp + rename)
    process.stdout.write(`wrote /${name} slash command -> ${file}\n  In Claude Code, type: /${name} serve   (or /${name} goal …, /${name} report …)\n`);
  } catch (e) {
    process.stdout.write(`could not write the slash command (${e.message}). Skipping.\n`);
    process.exitCode = 1;
  }
}

function cmdHelp() {
  process.stdout.write(`ccmd — Command Center (machine-wide agent status board)
  This binary ships inside the skill and is NOT on your PATH by default. Run it by
  absolute path, or run 'ccmd link' once to expose it as a real 'ccmd' command.
  ccmd link [--dir <bin>]                            # symlink this binary onto PATH (~/.local/bin)
  ccmd install [--name ccmd] [--dir <commands>]      # write a Claude Code slash command (~/.claude/commands/ccmd.md)
  ccmd where                                         # print this binary's absolute path
  ccmd init [--theme swiss|terminal|soft] [--accent "#0a84ff"] [--features goals,seen,mirror] [--product "id:Label:repo1,repo2"]…
                                                     # first-run setup; no flags + a TTY => wizard
  ccmd demo                                          # seed a realistic example store (for preview/screenshots)
  ccmd serve [--port 7777]                           # live local dashboard (marking read persists here)  ← default view
  ccmd report --status IN_PROGRESS|BLOCKED|DONE --summary "…" [--task …] [--progress …] --done "a;b" --in-flight "…" --next "…" --blocked "…" [--agent name] [--tier max] [--note "…"]
  ccmd signal --kind blocker|question --msg "…"      # prints an id; clear it with:
  ccmd resolve <id>
  ccmd goal --title "…" --summary "…" [--prompt-path f] [--links "u;u"] [--prereqs "…"] [--hours N] [--status ready|waiting|draft] [--project p]
  ccmd goal --done <id>                              # curated async-work shelf (pairs with Claude Code's /goal)
  ccmd render                                        # regenerate dashboard.html
  ccmd prune [--presence]                            # archive DONE/read entries
  ccmd read                                          # stdin: a "ccmd-read: k1, k2" line → marks read (validated, no shell)
  ccmd seen <key> | ccmd unseen <key>                # key: entry:<project>/<branch> | signal:<id>
  ccmd check [--since <epoch_ms>]                    # JSON {exists,fresh} for the cwd's entry (Stop hook)
  ccmd mirror [--fragment] [--out file.html]         # optional hosted-mirror HTML export
  ccmd set-url <url> | ccmd get-url                  # the hosted mirror URL
  ccmd data                                          # JSON of the board model
  Store: $ACC_HOME (default ~/.agents-command-center). project/branch auto-derive from git.
  This is the only help (there is no per-command --help).
`);
}

// ---------- dispatch ----------
// Commands invoked by hooks must never break the hook: the hook scripts already
// guard with `|| true`, and we also keep their failures quiet. Everything else
// surfaces a non-zero exit so scripting/CI can detect real failures.
const MUTATING_CMDS = new Set(['report', 'signal', 'resolve', 'goal', 'loop', 'prune',
  'init', 'demo', 'seen', 'unseen', 'set-url', 'install', 'link', 'render', 'mirror']);
function main() {
  const [, , cmd, ...rest] = process.argv;
  const args = parseArgs(rest);
  // `--help`/`-h` anywhere prints help and NEVER mutates state.
  // (Fixes the `report --help` footgun that used to overwrite your row with an empty report.)
  if ((args.help || args.h) && cmd && cmd !== 'get-url') return cmdHelp();
  try {
    switch (cmd) {
      case 'link': return cmdLink(args);
      case 'where': return cmdWhere();
      case 'install': return cmdInstall(args);
      case 'init': return cmdInit(args);
      case 'demo': return cmdDemo(args);
      case 'report': return cmdReport(args);
      case 'signal': return cmdSignal(args);
      case 'resolve': return cmdResolve(args);
      case 'render': return cmdRender(args);
      case 'mirror': return cmdMirror(args);
      case 'prune': return cmdPrune(args);
      case 'read': return cmdRead(args);
      case 'seen': return cmdSeen(args);
      case 'unseen': return cmdUnseen(args);
      case 'check': return cmdCheck(args);
      case 'set-url': return cmdSetUrl(args);
      case 'get-url': return cmdGetUrl();
      case 'goal': return cmdGoal(args);
      case 'loop': // deprecated alias — the feature was renamed to "goals"
        process.stderr.write("ccmd: 'loop' was renamed to 'goal' — use 'ccmd goal'. (running it for you)\n");
        return cmdGoal(args);
      case 'data': return cmdData();
      case 'serve': return cmdServe(args);
      case 'help': case '--help': case '-h': case undefined: return cmdHelp();
      default: process.stdout.write(`unknown command: ${cmd}\n`); return cmdHelp();
    }
  } catch (e) {
    // Never throw out of a hook, but surface real failures with a non-zero exit.
    // Hook scripts call the CLI with `|| true`, so this stays fail-open for them.
    process.stderr.write(`ccmd: ${e && e.message ? e.message : e}\n`);
    process.exitCode = 1;
  }
}
main();
